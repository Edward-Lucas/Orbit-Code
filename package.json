{
  "name": "orbit-code",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Code Editor - Go Desktop + TypeScript AI Engine",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/webview-ui dev",
    "dev:ai": "bun run --cwd packages/ai-engine dev",
    "build": "bun run --cwd packages/webview-ui build",
    "build:ai": "bun run --cwd packages/ai-engine build",
    "typecheck": "bun turbo typecheck",
    "lint": "oxlint"
  },
  "devDependencies": {
    "oxlint": "^0.16.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "bun@1.3.14"
}
